# Neuroxus — Variáveis de Ambiente
#
# Copie este arquivo como .env e preencha os valores:
#   cp .env.example .env

# URL de conexão com o ArangoDB
# Local (Docker): http://localhost:8529
# Remoto (Oracle): https://arango.seudominio.com
ARANGO_URL=

# Usuário do ArangoDB
# Local: root
# Remoto: app_user
ARANGO_USER=

# Senha do ArangoDB
ARANGO_PASS=

# Nome do banco de dados
DB_NAME=knowledgebase
