# Neuroxus — Variáveis de Ambiente
#
# Copie este arquivo como .env e preencha os valores:
#   cp .env.example .env

# URL de conexão com o ArangoDB
# Local (Docker): http://localhost:8529
# Remoto (GCP): http://<IP_DA_VM>:8529
ARANGO_URL=

# Usuário do ArangoDB
# Local: root
# Remoto: app_user
ARANGO_USER=

# Senha do ArangoDB
ARANGO_PASS=

# Nome do banco de dados
DB_NAME=knowledgebase

# Timeout de conexão em milissegundos (opcional, default 30000)
ARANGO_TIMEOUT=30000
